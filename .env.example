# ── 演出信息（从目标 URL 提取）────────────────────
GOODS_CODE=26005973
PLACE_CODE=26000437
BIZ_CODE=10965
LANG=zh-CN

# ── NOL 账号 ──────────────────────────────────────
# 留空则脚本暂停，等待用户在浏览器中手动登录
NOL_EMAIL=
NOL_PASSWORD=

# ── 浏览器 ────────────────────────────────────────
# 留空则自动检测系统 Chrome/Chromium
CHROMIUM_PATH=
HEADLESS=false

# ── 购票行为 ──────────────────────────────────────
SEAT_GRADE_PREFERENCE=VIP,R,S,A
MAX_TICKETS=2
# true = 到支付页前停止，由人工完成支付
STOP_BEFORE_PAYMENT=true

# ── 轮询参数 ──────────────────────────────────────
POLL_INTERVAL=1.5
QUEUE_TIMEOUT=600
